# Convertale — local environment configuration
#
# Copy this file to `.env` at the project root and fill in real values.
# NEVER commit `.env` — see .gitignore. If a real .env with live credentials
# was ever committed or shared, rotate every one of these credentials
# immediately (Clerk keys, DASHSCOPE/QWEN key, Neon/Neo4j passwords, etc.)
# and scrub it from git history.

# ── Shared ──────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── Next.js / Clerk (frontend) ──────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── FastAPI / Clerk (backend) ───────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
CLERK_ISSUER=https://replace-me.clerk.accounts.dev
CLERK_JWKS_URL=https://replace-me.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWT_AUDIENCE=

# ── Qwen Cloud / DashScope ───────────────────────────────
# Get it at: https://dashscope.console.aliyun.com/apiKey
# Used for: LLM scriptwriting, Qwen-VL visual critic, Wan video generation.
QWEN_API_KEY=replace_me
DASHSCOPE_API_KEY=replace_me
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── FAL.ai (HappyHorse lip-sync) — optional ─────────────
FAL_API_KEY=

# ── Neon Postgres ────────────────────────────────────────
# Use Neon's pooled connection string for app runtime.
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-pooler.region.aws.neon.tech/convertale?ssl=require
ALEMBIC_DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/convertale?sslmode=require
NEON_BRANCH_STRATEGY=per-environment

# ── Neo4j AuraDB ─────────────────────────────────────────
NEO4J_URI=neo4j+s://replace-me.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_me
NEO4J_DATABASE=neo4j
NEO4J_TIER=AuraDB Free

# ── Queue (Celery broker/backend) ───────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Alibaba Cloud / Terraform / CI (deploy-time only) ───
# NOTE: ALIBABA_CLOUD_REGION and ALICLOUD_REGION were both present and
# always set to the same value — pick one. Terraform's alicloud provider
# reads ALICLOUD_* by convention, so that's the one kept here.
ALIBABA_CLOUD_ACCESS_KEY_ID=replace_me
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace_me
ALICLOUD_REGION=us-west-1
ACR_REGISTRY=replace-me-registry.us-west-1.cr.aliyuncs.com
ACR_NAMESPACE=convertale
ACR_USERNAME=replace_me
ACR_PASSWORD=replace_me
ACK_CLUSTER_ID=replace_me
KUBE_CONFIG_DATA=base64_encoded_kubeconfig

# ── Reserved for roadmap features (not read by any code yet) ───────────
# These are placeholders for the YouTube publishing / distribution agents
# described in README.md but not yet implemented. Keeping them documented
# here so the config surface and the roadmap stay in sync; remove this
# section once those agents land, or move each var up into the section
# above as it becomes live.
ANTHROPIC_API_KEY=replace_me
YOUTUBE_CLIENT_ID=replace_me
YOUTUBE_CLIENT_SECRET=replace_me
HAPPYHORSE_WHITELIST_REFERENCE=replace_me
YOUTUBE_QUOTA_REQUEST_REFERENCE=replace_me
