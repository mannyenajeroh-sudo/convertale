# Convertale — local development .env
# This file is read by the FastAPI backend (pydantic-settings).
# For Next.js, values also live in .env.local.
# NEVER commit this file — it contains real credentials.

# ── App ──────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── Qwen Cloud / DashScope ───────────────────────────────
# CRITICAL: Workspace API keys (sk-ws-...) must NOT contain dots (.).
# The dots shown in Alibaba Cloud console are for readability ONLY.
# When copying your key, remove ALL dots to get one continuous string.
# Example: sk-ws-H.XILIHL.sLTV.MEYCIQD... → sk-ws-HXILIHLsLTVMEYCIQD...
# 
# Also ensure QWEN_BASE_URL matches your workspace domain exactly.
# Find it in Alibaba Cloud Console > Model Studio > API Key > \"OpenAI Compatible Endpoint\"
# It will look like: https://ws-XXXXXXXX.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-ws-HYYPLEPyDFBMEYCIQDcreUM1q8RGR3A4VgRa9RqlRXdmEru0jOVj1gz0fx3CAIhAMDSTN7SWugxsgFWUeEQPbgBRPlMMmybY2gekfecMPRd
DASHSCOPE_API_KEY=sk-ws-HYYPLEPyDFBMEYCIQDcreUM1q8RGR3A4VgRa9RqlRXdmEru0jOVj1gz0fx3CAIhAMDSTN7SWugxsgFWUeEQPbgBRPlMMmybY2gekfecMPRd
QWEN_BASE_URL=https://ws-r0izv5baffzpmfae.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

# ── Clerk ────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZGFyaW5nLW5ld3QtMjMuY2xlcmsuYWNjb3VudHMuZGV2JA
