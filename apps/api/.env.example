# Convertale — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env or .env.local with real credentials.

# ── App ──────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── Qwen Cloud / DashScope ───────────────────────────────
# CRITICAL INSTRUCTIONS:
# 1. Workspace API keys (sk-ws-...) MUST have ALL dots (.) removed.
#    The console shows dots for readability ONLY - they are NOT part of the key.
#    Example: sk-ws-H.XILIHL.sLTV.MEYCIQD... → sk-ws-HXILIHLsLTVMEYCIQD...
#
# 2. Workspace keys MUST use the workspace-specific base URL.
#    Find it in Alibaba Cloud Console > Model Studio > API Key
#    Look for "OpenAI Compatible Endpoint" which will be:
#    https://ws-XXXXXXXX.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
#
# 3. Standard keys (sk-...) typically use:
#    https://dashscope.aliyuncs.com/compatible-mode/v1
#
# QWEN_API_KEY=<your-key-without-dots>
# DASHSCOPE_API_KEY=<your-key-without-dots>
# QWEN_BASE_URL=<your-workspace-or-standard-endpoint>

# Example for workspace key (REMOVE dots from your actual key):
# QWEN_API_KEY=sk-ws-HXXAMPLEKEYWITHOUTDOTS1234567890ABCDEF
# DASHSCOPE_API_KEY=sk-ws-HXXAMPLEKEYWITHOUTDOTS1234567890ABCDEF
# QWEN_BASE_URL=https://ws-r0izv5baffzpmfae.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

# ── Clerk ────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_JWT_AUDIENCE=

# ── CORS ─────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Neon Postgres ────────────────────────────────────────
DATABASE_URL=
ALEMBIC_DATABASE_URL=

# ── Neo4j AuraDB ─────────────────────────────────────────
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── Redis / Celery ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── FAL.ai ───────────────────────────────────────────────
FAL_API_KEY=
